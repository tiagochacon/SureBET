# ============================================================
# SureBet — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# ============================================================

# The Odds API — https://the-odds-api.com
# Obtenha sua chave em: https://the-odds-api.com/#get-access
ODDS_API_KEY=your_odds_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://surebet:surebet_secret@localhost:5432/surebet_db

# Redis
REDIS_URL=redis://localhost:6379

# Backend
NODE_ENV=development
PORT=3001

# Configurações do sistema
POLLING_INTERVAL_SECONDS=60
ODDS_CACHE_TTL_SECONDS=90
MIN_ARBITRAGE_MARGIN=0.005
MIN_MINUTES_TO_GAME=5

# Frontend (prefixo NEXT_PUBLIC_ = exposto ao browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
